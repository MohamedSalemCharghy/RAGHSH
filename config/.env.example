# Copy this file to config/.env and fill in local secrets.
GWDG_API_KEY=your-api-key-here
GWDG_API_BASE=https://chat-ai.academiccloud.de/v1

# Optional runtime overrides.
# FASTEMBED_CACHE_PATH=/absolute/path/to/fastembed-cache
# HF_HOME=/absolute/path/to/huggingface-cache
# RAG_DATA_DIR=/absolute/path/to/raghsh-data
# RAG_ARTIFACTS_DIR=/absolute/path/to/raghsh-artifacts
# RAG_CONFIG_DIR=/absolute/path/to/raghsh-config
